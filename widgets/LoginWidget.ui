  <property name="styleSheet">
   <string notr="true">
QWidget#LoginWidget { background: #F0F7EE; }
QFrame#loginCard { background: white; border-radius: 20px; border: 1px solid #C0DD97; }
QLabel#logoIcon { background: #EAF3DE; border-radius: 12px; font-size: 22px; }
QLabel#logoText { font-size: 22px; font-weight: 500; color: #27500A; }
QLabel#logoSubtitle { font-size: 13px; color: #639922; }
QFrame#divider, QFrame#orLeft, QFrame#orRight { background: #EAF3DE; border: none; max-height: 1px; }
QLabel#errorLabel { color: #A32D2D; background: #FCEBEB; border-radius: 8px; padding: 8px; font-size: 13px; }
QLineEdit { border: 1px solid #C0DD97; border-radius: 10px; padding: 0 10px; font-size: 14px; color: #27500A; background: #FAFFF8; min-height: 40px; max-height: 40px; }
QLineEdit:focus { border-color: #639922; background: #F3FBED; }
QLabel#userIcon, QLabel#lockIcon { font-size: 17px; background: transparent; border: none; }
QPushButton#eyeBtn { background: transparent; border: none; font-size: 16px; }
QCheckBox#saveIdBox { font-size: 13px; color: #5F5E5A; }
QCheckBox#saveIdBox::indicator { width: 15px; height: 15px; border: 1px solid #C0DD97; border-radius: 4px; background: white; }
QCheckBox#saveIdBox::indicator:checked { background: #639922; border-color: #639922; }
QPushButton#forgotBtn { font-size: 13px; color: #639922; background: transparent; border: none; padding: 0; }
QPushButton#forgotBtn:hover { color: #27500A; }
QPushButton#loginBtn { background: #3B6D11; color: white; border: none; border-radius: 10px; font-size: 15px; font-weight: 500; }
QPushButton#loginBtn:hover { background: #27500A; }
QPushButton#loginBtn:disabled { background: #B4B2A9; }
QLabel#orLabel { font-size: 12px; color: #B4B2A9; padding: 0 8px; background: transparent; }
QPushButton#registerBtn { background: transparent; color: #3B6D11; border: 1px solid #97C459; border-radius: 10px; font-size: 14px; }
QPushButton#registerBtn:hover { background: #EAF3DE; }
QLabel#statusLabel { font-size: 12px; color: #B4B2A9; background: transparent; }
   </string>
