  <property name="windowTitle"><string>수화배움 — 회원가입</string></property>
  <property name="styleSheet">
   <string notr="true">
QWidget#RegisterWidget { background: #F0F7EE; }
QFrame#regCard { background: white; border-radius: 20px; border: 1px solid #C0DD97; }
QLabel#titleLabel { font-size: 20px; font-weight: 500; color: #27500A; }
QLabel#subLabel   { font-size: 13px; color: #639922; }
QFrame#divider    { background: #EAF3DE; border: none; max-height: 1px; }
QLabel#errorLabel { color:#A32D2D; background:#FCEBEB; border-radius:8px; padding:8px; font-size:13px; }
QLabel#fieldLabel { font-size: 13px; color: #5F5E5A; }
QLineEdit {
    border: 1px solid #C0DD97; border-radius: 10px;
    padding: 0 10px; font-size: 14px; color: #27500A;
    background: #FAFFF8; min-height: 40px; max-height: 40px;
}
QLineEdit:focus { border-color: #639922; background: #F3FBED; }
QRadioButton {
    font-size: 13px; color: #27500A; spacing: 6px;
}
QRadioButton::indicator {
    width: 16px; height: 16px;
    border: 1px solid #C0DD97; border-radius: 8px; background: white;
}
QRadioButton::indicator:checked {
    background: #639922; border-color: #639922;
}
QCheckBox#consentBox {
    font-size: 12px; color: #5F5E5A;
}
QCheckBox#consentBox::indicator {
    width: 15px; height: 15px;
    border: 1px solid #C0DD97; border-radius: 4px; background: white;
}
QCheckBox#consentBox::indicator:checked { background: #639922; border-color: #639922; }
QCheckBox#deafBox {
    font-size: 13px; color: #27500A;
}
QCheckBox#deafBox::indicator {
    width: 15px; height: 15px;
    border: 1px solid #C0DD97; border-radius: 4px; background: white;
}
QCheckBox#deafBox::indicator:checked { background: #639922; border-color: #639922; }
QPushButton#registerBtn {
    background: #3B6D11; color: white; border: none;
    border-radius: 10px; font-size: 15px; font-weight: 500;
}
QPushButton#registerBtn:hover { background: #27500A; }
QPushButton#registerBtn:disabled { background: #B4B2A9; }
QPushButton#backBtn {
    background: transparent; color: #3B6D11;
    border: 1px solid #97C459; border-radius: 10px; font-size: 14px;
}
QPushButton#backBtn:hover { background: #EAF3DE; }
   </string>
