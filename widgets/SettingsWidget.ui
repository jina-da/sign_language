  <property name="styleSheet">
   <string notr="true">QWidget#SettingsWidget { background: #F0F7EE; }
QWidget#headerArea { background: white; border-bottom: 1px solid #C0DD97; }
QLabel#headerLabel { font-size: 14px; font-weight: 500; color: #27500A; }
QScrollArea#scrollArea { background: #F0F7EE; border: none; }
QWidget#scrollContent { background: #F0F7EE; }
QWidget#sectionCard { background: white; border-radius: 14px; border: 1px solid #C0DD97; }
QLabel#sectionTitle { font-size: 13px; font-weight: 500; color: #3B6D11; }
QLabel#itemLabel { font-size: 13px; color: #27500A; }
QLabel#itemDesc { font-size: 11px; color: #888780; }
QLabel#statusLabel { font-size: 12px; color: #639922; }
QSpinBox#goalSpinBox {
    border: 1px solid #C0DD97; border-radius: 8px;
    padding: 4px 8px; font-size: 13px; color: #27500A;
    background: #FAFFF8; min-width: 70px; max-width: 70px;
}
QSpinBox#goalSpinBox:focus { border-color: #639922; }
QRadioButton { font-size: 13px; color: #27500A; }
QRadioButton::indicator { width: 16px; height: 16px; }
QCheckBox { font-size: 13px; color: #27500A; }
QCheckBox::indicator { width: 16px; height: 16px; }
QLineEdit#pwEdit {
    border: 1px solid #C0DD97; border-radius: 8px;
    padding: 6px 12px; font-size: 13px; color: #27500A;
    background: #FAFFF8; min-width: 200px; max-width: 200px;
}
QLineEdit#pwEdit:focus { border-color: #639922; }
QPushButton#saveBtn {
    background: #3B6D11; color: white; border: none;
    border-radius: 8px; font-size: 13px; font-weight: 500;
    padding: 9px 28px;
}
QPushButton#saveBtn:hover { background: #27500A; }
QPushButton#saveBtn:disabled { background: #B4B2A9; }
QPushButton#withdrawBtn {
    background: transparent; color: #A93226;
    border: 1px solid #F1948A; border-radius: 8px;
    font-size: 13px; padding: 8px 20px;
}
QPushButton#withdrawBtn:hover { background: #FDEDEC; }
QFrame#divider { background: #EAF3DE; max-height: 1px; min-height: 1px; }</string>
