<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>MainWindow</class>
 <widget class="QWidget" name="MainWindow">
  <property name="geometry">
   <rect><x>0</x><y>0</y><width>1024</width><height>680</height></rect>
  </property>
  <property name="minimumSize"><size><width>900</width><height>660</height></size></property>
  <property name="windowTitle"><string>수화배움</string></property>
  <property name="styleSheet">
   <string notr="true">
QWidget#MainWindow { background: #F0F7EE; }

/* TopBar */
QWidget#topBar { background: #3B6D11; }
QLabel#logoIcon { font-size: 20px; }
QLabel#logoText { font-size: 16px; font-weight: 500; color: #C0DD97; }
QPushButton#userBtn { font-size: 13px; color: #EAF3DE; background: rgba(255,255,255,0.15); border-radius: 8px; padding: 4px 10px; border: none; } QPushButton#userBtn:hover { background: rgba(255,255,255,0.25); }

/* NavBar */
QWidget#navBar { background: white; border-bottom: 1px solid #C0DD97; }
QPushButton#navHome, QPushButton#navStudy, QPushButton#navReview,
QPushButton#navDict, QPushButton#navGame,  QPushButton#navSettings {
    font-size: 13px; color: #5F5E5A;
    border-bottom: 2px solid transparent;
    padding: 0 14px; background: transparent;
}

/* 홈탭 */
QScrollArea#homeTab { background: #F0F7EE; border: none; }
QWidget#homeContent  { background: #F0F7EE; }

/* 인사 배너 */
QWidget#helloBanner  { background: #3B6D11; border-radius: 14px; }
QLabel#bannerAvatar  { font-size: 20px; background: rgba(255,255,255,0.15); border-radius: 22px; }
QLabel#helloLabel    { font-size: 15px; font-weight: 500; color: white; }
QLabel#helloSub      { font-size: 12px; color: #97C459; }
QLabel#goalLabel     { font-size: 22px; font-weight: 500; color: white; }
QLabel#goalSub       { font-size: 11px; color: #97C459; }

/* 진도 카드 */
QWidget#progressCard  { background: white; border-radius: 14px; border: 1px solid #C0DD97; }
QLabel#progressTitle  { font-size: 13px; color: #5F5E5A; }
QLabel#progressText   { font-size: 12px; color: #888780; }
QProgressBar#progressBar {
    background: #EAF3DE; border-radius: 5px; border: none;
}
QProgressBar#progressBar::chunk {
    background: #639922; border-radius: 5px;
}

/* 모드 카드 */
QFrame#studyCard, QFrame#reviewCard,
QFrame#gameCard,  QFrame#dictCard {
    background: white; border-radius: 14px;
    border: 1px solid #C0DD97; min-height: 120px;
}
QLabel#studyIcon  { font-size: 18px; border-radius: 10px; min-width: 36px; max-width: 36px; min-height: 36px; max-height: 36px; background: #EAF3DE; }
QLabel#reviewIcon { font-size: 18px; border-radius: 10px; min-width: 36px; max-width: 36px; min-height: 36px; max-height: 36px; background: #FFF8E6; }
QLabel#gameIcon   { font-size: 18px; border-radius: 10px; min-width: 36px; max-width: 36px; min-height: 36px; max-height: 36px; background: #FBEAF0; }
QLabel#dictIcon   { font-size: 18px; border-radius: 10px; min-width: 36px; max-width: 36px; min-height: 36px; max-height: 36px; background: #E6F1FB; }
QLabel#studyTitle, QLabel#reviewTitle,
QLabel#gameTitle,  QLabel#dictTitle  { font-size: 13px; font-weight: 500; color: #27500A; }
QLabel#studySub, QLabel#reviewSub,
QLabel#gameSub,  QLabel#dictSub     { font-size: 11px; color: #888780; }
QLabel#studyBadge  { font-size: 11px; background: #EAF3DE; color: #3B6D11; border-radius: 99px; padding: 2px 8px; }
QLabel#reviewBadge { font-size: 11px; background: #FFF8E6; color: #854F0B; border-radius: 99px; padding: 2px 8px; }
QLabel#gameBadge   { font-size: 11px; background: #FBEAF0; color: #72243E; border-radius: 99px; padding: 2px 8px; }
QLabel#dictBadge   { font-size: 11px; background: #E6F1FB; color: #0C447C; border-radius: 99px; padding: 2px 8px; }

/* 단어 카드 */
QWidget#wordCard      { background: white; border-radius: 14px; border: 1px solid #C0DD97; }
QLabel#wordCardTitle  { font-size: 13px; color: #5F5E5A; padding-bottom: 8px; }

/* placeholder 탭 */
QWidget#studyTab, QWidget#reviewTab, QWidget#dictTab,
QWidget#gameTab,  QWidget#settingsTab { background: #F0F7EE; }
QLabel#phStudy, QLabel#phReview, QLabel#phDict,
QLabel#phGame,  QLabel#phSettings { font-size: 16px; color: #888780; }
   </string>
