  <property name="geometry">
   <rect><x>0</x><y>0</y><width>900</width><height>600</height></rect>
  </property>
  <property name="styleSheet">
   <string notr="true">
QWidget#StudyWidget { background: #F0F7EE; }

/* 상단 진도 바 영역 */
QWidget#headerArea { background: white; border-bottom: 1px solid #C0DD97; }
QLabel#wordCountLabel { font-size: 13px; color: #5F5E5A; }
QLabel#wordIndexLabel { font-size: 13px; font-weight: 500; color: #3B6D11; }
QProgressBar#studyProgress {
    background: #EAF3DE; border-radius: 4px; border: none;
}
QProgressBar#studyProgress::chunk { background: #639922; border-radius: 4px; }

/* 왼쪽: 영상 + 단어 정보 */
QWidget#videoArea {
    background: white; border-radius: 14px; border: 1px solid #C0DD97;
}
QLabel#videoPlayer {
    background: #1a1a2e; border-radius: 10px;
    color: #888780; font-size: 14px;
}
QLabel#wordLabel    { font-size: 28px; font-weight: 500; color: #27500A; }
QLabel#categoryLabel {
    font-size: 12px; background: #EAF3DE; color: #3B6D11;
    border-radius: 99px; padding: 2px 10px;
}
QPushButton#replayBtn {
    background: #EAF3DE; color: #3B6D11; border: none;
    border-radius: 8px; font-size: 13px; padding: 6px 14px;
}
QPushButton#replayBtn:hover { background: #C0DD97; }

/* 속도 조절 버튼 */
QPushButton#speed025, QPushButton#speed050,
QPushButton#speed100, QPushButton#speed150, QPushButton#speed200 {
    background: #F0F7EE; color: #5F5E5A; border: 1px solid #C0DD97;
    border-radius: 6px; font-size: 12px; padding: 4px 8px;
}
QPushButton#speed025:checked, QPushButton#speed050:checked,
QPushButton#speed100:checked, QPushButton#speed150:checked,
QPushButton#speed200:checked {
    background: #3B6D11; color: white; border-color: #3B6D11;
}

/* 오른쪽: 카메라 + 인식 결과 */
QWidget#cameraArea {
    background: white; border-radius: 14px; border: 1px solid #C0DD97;
}
QLabel#cameraView {
    background: #1a1a2e; border-radius: 10px;
    color: #888780; font-size: 14px;
}

/* 상태 표시 */
QLabel#recordingLabel {
    font-size: 13px; color: #E24B4A; font-weight: 500;
}
QLabel#statusLabel { font-size: 13px; color: #5F5E5A; }

/* 결과 카드 */
QWidget#resultCard {
    border-radius: 12px; border: 1px solid #C0DD97;
}
QLabel#verdictLabel { font-size: 20px; font-weight: 500; }
QLabel#confidenceLabel { font-size: 13px; color: #5F5E5A; }

/* 하단 버튼 */
QPushButton#skipBtn {
    background: transparent; color: #888780;
    border: 1px solid #C0DD97; border-radius: 8px;
    font-size: 13px; padding: 8px 20px;
}
QPushButton#skipBtn:hover { background: #F0F7EE; }
QPushButton#nextBtn {
    background: #3B6D11; color: white; border: none;
    border-radius: 8px; font-size: 13px;
    font-weight: 500; padding: 8px 28px;
}
QPushButton#nextBtn:hover { background: #27500A; }
QPushButton#nextBtn:disabled { background: #B4B2A9; }
   </string>
